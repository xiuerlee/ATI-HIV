recursive = TRUE
)
write.csv(
best_fit_params_repaired2,
"../Rdata/model_selection_results/best_fit_params_repaired2.csv",
row.names = FALSE
)
write.csv(
model_fit_table_repaired2,
"../Rdata/model_selection_results/model_fit_summary_repaired2.csv",
row.names = FALSE
)
write.csv(
aicc_table_repaired2,
"../Rdata/model_selection_results/aicc_table_repaired2.csv",
row.names = FALSE
)
write.csv(
most_parsimonious_models_repaired2,
"../Rdata/model_selection_results/most_parsimonious_models_repaired2_deltaAICc_lt5.csv",
row.names = FALSE
)
get_residual_table_from_params <- function(model_name, params_table) {
model_row <- candidate_models %>%
filter(model == model_name) %>%
slice(1)
model_flags <- c(
za = as.numeric(model_row$za),
zdelta = as.numeric(model_row$zdelta),
zp = as.numeric(model_row$zp)
)
pars_row <- params_table %>%
filter(model == model_name) %>%
slice(1)
pars <- c(
fixed_pars,
a_L = pars_row$a_L,
delta = pars_row$delta,
p = pars_row$p,
theta_a = pars_row$theta_a,
theta_delta = pars_row$theta_delta,
theta_p = pars_row$theta_p
)
sim <- simulate_all(
pars = pars,
model_flags = model_flags
)
pred <- make_predictions(sim)
data_fit %>%
left_join(
pred,
by = c("id", "group", "time", "variable")
) %>%
mutate(
model = model_name,
resid = pred - value,
resid2 = resid^2
)
}
resid_top_models <- bind_rows(
get_residual_table_from_params("Ma_delta_p", best_fit_params_repaired2),
get_residual_table_from_params("Mdelta_p", best_fit_params_repaired2)
)
resid_top_models %>%
group_by(model, variable) %>%
summarise(
n = n(),
RSS = sum(resid2, na.rm = TRUE),
RMSE = sqrt(mean(resid2, na.rm = TRUE)),
mean_resid = mean(resid, na.rm = TRUE),
.groups = "drop"
) %>%
print(n = Inf)
resid_top_models %>%
group_by(model, group, variable) %>%
summarise(
n = n(),
RSS = sum(resid2, na.rm = TRUE),
RMSE = sqrt(mean(resid2, na.rm = TRUE)),
mean_resid = mean(resid, na.rm = TRUE),
.groups = "drop"
) %>%
print(n = Inf)
resid_top_models %>%
filter(variable == "pVL") %>%
mutate(
time_bin = cut(
time,
breaks = c(-Inf, 0, 4, 8, 12, 16, 24, Inf),
labels = c("0", "0-4", "4-8", "8-12", "12-16", "16-24", ">24")
)
) %>%
group_by(model, group, time_bin) %>%
summarise(
n = n(),
RSS = sum(resid2, na.rm = TRUE),
RMSE = sqrt(mean(resid2, na.rm = TRUE)),
mean_resid = mean(resid, na.rm = TRUE),
.groups = "drop"
) %>%
print(n = Inf)
resid_top_models %>%
filter(
model == "Ma_delta_p",
variable == "pVL"
) %>%
group_by(group, id) %>%
summarise(
n = n(),
RSS = sum(resid2, na.rm = TRUE),
RMSE = sqrt(mean(resid2, na.rm = TRUE)),
mean_resid = mean(resid, na.rm = TRUE),
min_resid = min(resid, na.rm = TRUE),
max_resid = max(resid, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(desc(RSS)) %>%
print(n = Inf)
plot_model_fit <- function(model_name, params_table) {
model_row <- candidate_models %>%
filter(model == model_name) %>%
slice(1)
model_flags <- c(
za = as.numeric(model_row$za),
zdelta = as.numeric(model_row$zdelta),
zp = as.numeric(model_row$zp)
)
pars_row <- params_table %>%
filter(model == model_name) %>%
slice(1)
pars <- c(
fixed_pars,
a_L = pars_row$a_L,
delta = pars_row$delta,
p = pars_row$p,
theta_a = pars_row$theta_a,
theta_delta = pars_row$theta_delta,
theta_p = pars_row$theta_p
)
sim <- simulate_all(
pars = pars,
model_flags = model_flags
)
pred <- make_predictions(sim)
plot_data <- data_fit %>%
left_join(
pred,
by = c("id", "group", "time", "variable")
)
ggplot(plot_data, aes(x = time)) +
geom_point(aes(y = value), size = 1.5) +
geom_line(aes(y = pred), linewidth = 0.7) +
facet_grid(variable ~ id, scales = "free_y") +
theme_bw() +
labs(
title = paste("Model fit:", model_name),
y = "log10 scale",
x = "Time"
)
}
plot_model_fit(
model_name = "Ma_delta_p",
params_table = best_fit_params_repaired2
)
