# ============================================================
# LOD-aware residual diagnostic
# 不重新拟合，只用已有 best_fit_params_repaired2 检查残差结构
# ============================================================
get_residual_table_from_params_lod <- function(model_name, params_table) {
model_row <- candidate_models %>%
filter(model == model_name) %>%
slice(1)
model_flags <- c(
za = as.numeric(model_row$za),
zdelta = as.numeric(model_row$zdelta),
zp = as.numeric(model_row$zp)
)
pars_row <- params_table %>%
filter(model == model_name) %>%
slice(1)
pars <- c(
fixed_pars,
a_L = pars_row$a_L,
delta = pars_row$delta,
p = pars_row$p,
theta_a = pars_row$theta_a,
theta_delta = pars_row$theta_delta,
theta_p = pars_row$theta_p
)
sim <- simulate_all(
pars = pars,
model_flags = model_flags
)
pred <- make_predictions(sim)
data_fit %>%
left_join(
pred,
by = c("id", "group", "time", "variable")
) %>%
mutate(
model = model_name,
is_censored_pVL = variable == "pVL" &
!is.na(lod_raw) &
!is.na(value_raw) &
value_raw <= lod_raw,
resid_plain = pred - value,
resid_lod = case_when(
is_censored_pVL ~ pmax(pred - lod, 0),
TRUE ~ pred - value
),
resid2_plain = resid_plain^2,
resid2_lod = resid_lod^2
)
}
resid_top_models_lod <- bind_rows(
get_residual_table_from_params_lod(
model_name = "Ma_delta_p",
params_table = best_fit_params_repaired2
),
get_residual_table_from_params_lod(
model_name = "Mdelta_p",
params_table = best_fit_params_repaired2
)
)
dim(resid_top_models_lod)
head(resid_top_models_lod)
resid_top_models_lod %>%
group_by(model, variable) %>%
summarise(
n = n(),
n_censored = sum(is_censored_pVL, na.rm = TRUE),
RSS_plain = sum(resid2_plain, na.rm = TRUE),
RSS_lod = sum(resid2_lod, na.rm = TRUE),
RMSE_plain = sqrt(mean(resid2_plain, na.rm = TRUE)),
RMSE_lod = sqrt(mean(resid2_lod, na.rm = TRUE)),
mean_resid_plain = mean(resid_plain, na.rm = TRUE),
mean_resid_lod = mean(resid_lod, na.rm = TRUE),
.groups = "drop"
) %>%
print(n = Inf)
resid_top_models_lod %>%
group_by(model, group, variable) %>%
summarise(
n = n(),
n_censored = sum(is_censored_pVL, na.rm = TRUE),
RSS_plain = sum(resid2_plain, na.rm = TRUE),
RSS_lod = sum(resid2_lod, na.rm = TRUE),
RMSE_plain = sqrt(mean(resid2_plain, na.rm = TRUE)),
RMSE_lod = sqrt(mean(resid2_lod, na.rm = TRUE)),
mean_resid_plain = mean(resid_plain, na.rm = TRUE),
mean_resid_lod = mean(resid_lod, na.rm = TRUE),
.groups = "drop"
) %>%
print(n = Inf)
resid_top_models_lod %>%
filter(variable == "pVL") %>%
mutate(
time_bin = case_when(
time == 0 ~ "0 d",
time <= 7 ~ "1-7 d",
time <= 14 ~ "8-14 d",
time <= 21 ~ "15-21 d",
time <= 28 ~ "22-28 d",
time <= 56 ~ "29-56 d",
time <= 112 ~ "57-112 d",
TRUE ~ ">112 d"
),
time_bin = factor(
time_bin,
levels = c(
"0 d",
"1-7 d",
"8-14 d",
"15-21 d",
"22-28 d",
"29-56 d",
"57-112 d",
">112 d"
)
)
) %>%
group_by(model, group, time_bin) %>%
summarise(
n = n(),
n_censored = sum(is_censored_pVL, na.rm = TRUE),
RSS_plain = sum(resid2_plain, na.rm = TRUE),
RSS_lod = sum(resid2_lod, na.rm = TRUE),
RMSE_plain = sqrt(mean(resid2_plain, na.rm = TRUE)),
RMSE_lod = sqrt(mean(resid2_lod, na.rm = TRUE)),
mean_resid_plain = mean(resid_plain, na.rm = TRUE),
mean_resid_lod = mean(resid_lod, na.rm = TRUE),
.groups = "drop"
) %>%
print(n = Inf)
resid_top_models_lod %>%
filter(
model == "Ma_delta_p",
variable == "pVL"
) %>%
group_by(group, id) %>%
summarise(
n = n(),
n_censored = sum(is_censored_pVL, na.rm = TRUE),
RSS_plain = sum(resid2_plain, na.rm = TRUE),
RSS_lod = sum(resid2_lod, na.rm = TRUE),
RMSE_plain = sqrt(mean(resid2_plain, na.rm = TRUE)),
RMSE_lod = sqrt(mean(resid2_lod, na.rm = TRUE)),
mean_resid_plain = mean(resid_plain, na.rm = TRUE),
mean_resid_lod = mean(resid_lod, na.rm = TRUE),
min_resid_lod = min(resid_lod, na.rm = TRUE),
max_resid_lod = max(resid_lod, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(desc(RSS_lod)) %>%
print(n = Inf)
individual_rss_lod <- resid_top_models_lod %>%
filter(
model == "Ma_delta_p",
variable == "pVL"
) %>%
group_by(group, id) %>%
summarise(
RSS_lod = sum(resid2_lod, na.rm = TRUE),
mean_resid_lod = mean(resid_lod, na.rm = TRUE),
.groups = "drop"
) %>%
arrange(desc(RSS_lod)) %>%
mutate(
rank = row_number(),
cumulative_RSS = cumsum(RSS_lod),
cumulative_fraction = cumulative_RSS / sum(RSS_lod)
)
print(individual_rss_lod, n = Inf)
compare_models_after_excluding_ids <- function(exclude_ids) {
tmp <- resid_top_models_lod %>%
filter(
variable %in% c("pVL", "DNA", "CD4"),
!(id %in% exclude_ids)
) %>%
group_by(model) %>%
summarise(
n = n(),
RSS_lod = sum(resid2_lod, na.rm = TRUE),
q = case_when(
model == "Ma_delta_p" ~ 6L,
model == "Mdelta_p" ~ 5L,
TRUE ~ NA_integer_
),
K = q + 1,
.groups = "drop"
) %>%
mutate(
RSS_safe = pmax(RSS_lod, .Machine$double.eps),
logLik = -0.5 * n * (log(2 * pi) + 1 + log(RSS_safe / n)),
AIC = -2 * logLik + 2 * K,
AICc = ifelse(
n > K + 1,
AIC + (2 * K * (K + 1)) / (n - K - 1),
NA_real_
)
) %>%
arrange(AICc) %>%
mutate(
delta_AICc = AICc - min(AICc, na.rm = TRUE),
Akaike_weight = exp(-0.5 * delta_AICc) /
sum(exp(-0.5 * delta_AICc), na.rm = TRUE),
rank = row_number(),
excluded = paste(exclude_ids, collapse = ", ")
)
tmp
}
compare_models_after_excluding_ids(character(0)) %>%
select(
excluded,
rank,
model,
n,
RSS_lod,
AICc,
delta_AICc,
Akaike_weight
) %>%
print(n = Inf)
